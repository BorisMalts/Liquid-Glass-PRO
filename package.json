{
  "name": "liquid-glass-pro",
  "version": "4.1.0",
  "description": "WebGL2 physically-based liquid glass rendering for the web with refraction, caustics, chromatic aberration, iridescence, spring physics, and CSS fallback.",
  "type": "module",
  "main": "./liquid-glass-pro.js",
  "module": "./liquid-glass-pro.js",
  "exports": {
    ".": {
      "import": "./liquid-glass-pro.js",
      "default": "./liquid-glass-pro.js"
    }
  },
  "files": [
    "liquid-glass-pro.js",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "python run.py",
    "start": "python run.py --no-open"
  },
  "dependencies": {
    "html2canvas": "^1.4.1"
  },
  "keywords": [
    "glass",
    "liquid-glass",
    "glassmorphism",
    "webgl",
    "webgl2",
    "refraction",
    "dispersion",
    "caustics",
    "chromatic-aberration",
    "iridescence",
    "frosted-glass",
    "backdrop-filter",
    "ui",
    "visual-effects"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BorisMalts/Liquid-Glass-PRO.git"
  },
  "bugs": {
    "url": "https://github.com/BorisMalts/Liquid-Glass-PRO/issues"
  },
  "homepage": "https://github.com/BorisMalts/Liquid-Glass-PRO#readme",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=18"
  }
}